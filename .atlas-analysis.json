  "keyFeatures": [
    "Cross-platform AI agent configurator (macOS, Linux, Windows)",
    "Interactive Bubbletea TUI with Rose Pine theme",
    "Supports 5 major AI coding agents (Claude Code, OpenCode, Gemini CLI, Cursor, VS Code Copilot)",
    "Engram persistent cross-session memory",
    "9-phase SDD (Spec-Driven Development) workflow orchestration",
    "11 curated coding skill files (SDD + foundation)",
    "Context7 MCP server for live framework documentation",
    "GGA (Gentleman Guardian Angel) AI provider switcher",
    "4 presets (full-gentleman, ecosystem-only, minimal, custom)",
    "3 persona modes (gentleman, neutral, custom)",
    "Platform-aware dependency detection and management",
    "Atomic backup/restore with rollback support",
    "CLI and interactive modes with dry-run capability"
  ],
  "publicApiSurface": [
    "gentle-ai (TUI mode)",
    "gentle-ai install --agent <agents> --preset <preset>",
    "gentle-ai install --agent <agents> --component <components> --skill <skills> --persona <persona>",
    "gentle-ai install --dry-run",
    "gentle-ai update",
    "gentle-ai version"
  ]
}
